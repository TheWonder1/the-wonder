# ── The Wonder — environment variable template ───────────────────────────────
# Copy this file to .env.local and fill in the values.
# .env.local is listed in .gitignore and will never be committed.

# Formspree contact form endpoint ID
# Sign up at https://formspree.io, create a form, paste the ID here.
# Example: NEXT_PUBLIC_FORMSPREE_ID=xnqygkdo
NEXT_PUBLIC_FORMSPREE_ID=YOUR_FORM_ID

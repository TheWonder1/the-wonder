# ── The Wonder — Git line-ending normalization ──────────────────────────────
# Ensures consistent LF line endings in the repo regardless of OS.
# Windows checkouts get CRLF (via core.autocrlf), but the repo stores LF.

* text=auto eol=lf

# Force LF for these file types in all environments
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.env* text eol=lf

# Binary files — no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.pdf  binary
